# AgentSpan SDK — Environment Configuration
# Copy to .env and fill in your values.

# Server API URL (default: http://localhost:8080/api)
AGENTSPAN_SERVER_URL=http://localhost:8080/api

# Auth credentials (optional for OSS)
# AGENTSPAN_AUTH_KEY=
# AGENTSPAN_AUTH_SECRET=

# Workflow timeout in seconds (0 = no timeout)
# AGENTSPAN_AGENT_TIMEOUT=0

# LLM retry count for failed calls
# AGENTSPAN_LLM_RETRY_COUNT=3

# Worker settings
# AGENTSPAN_WORKER_POLL_INTERVAL=100
# AGENTSPAN_WORKER_THREADS=1
# AGENTSPAN_AUTO_START_WORKERS=true
# AGENTSPAN_DAEMON_WORKERS=true

# Auto-start local server when URL points to localhost
# AGENTSPAN_AUTO_START_SERVER=true

# Auto-register LLM integrations (reads provider API keys from env)
# AGENTSPAN_INTEGRATIONS_AUTO_REGISTER=false

# SSE streaming
# AGENTSPAN_STREAMING_ENABLED=true

# LLM model for examples (provider/model format)
# AGENT_LLM_MODEL=openai/gpt-4o-mini
