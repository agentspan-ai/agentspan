# Agentspan JS SDK — environment variables
# Copy to .env and fill in values

# Conductor / Agentspan server URL
AGENTSPAN_SERVER_URL=http://localhost:8080

# Optional authentication (Orkes Cloud only — leave blank for local dev)
# AGENTSPAN_AUTH_KEY=your-key
# AGENTSPAN_AUTH_SECRET=your-secret

# LLM model in "provider/model" format
AGENT_LLM_MODEL=openai/gpt-4o

# Worker poll interval in ms (default: 100)
# AGENTSPAN_WORKER_POLL_INTERVAL=100

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# AGENTSPAN_LOG_LEVEL=INFO
