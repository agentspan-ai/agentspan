# Agentspan TypeScript SDK — environment variables
# Copy to .env and fill in values

# Server URL (auto-appends /api if missing)
AGENTSPAN_SERVER_URL=http://localhost:6767/api

# API key (Bearer token)
# AGENTSPAN_API_KEY=your-api-key

# Legacy authentication (Orkes Cloud)
# AGENTSPAN_AUTH_KEY=your-key
# AGENTSPAN_AUTH_SECRET=your-secret

# LLM retry count (default: 3)
# AGENTSPAN_LLM_RETRY_COUNT=3

# Worker poll interval in ms (default: 100)
# AGENTSPAN_WORKER_POLL_INTERVAL=100

# Concurrent executions per worker (default: 1)
# AGENTSPAN_WORKER_THREADS=1

# Auto-start workers on first run (default: true)
# AGENTSPAN_AUTO_START_WORKERS=true

# Auto-start local server (default: true)
# AGENTSPAN_AUTO_START_SERVER=true

# Kill workers on exit (default: true)
# AGENTSPAN_DAEMON_WORKERS=true

# Enable SSE streaming (default: true)
# AGENTSPAN_STREAMING_ENABLED=true

# Strict credential mode — no env var fallback (default: false)
# AGENTSPAN_CREDENTIAL_STRICT_MODE=false

# Auto-register LLM integrations (default: false)
# AGENTSPAN_INTEGRATIONS_AUTO_REGISTER=false

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# AGENTSPAN_LOG_LEVEL=INFO
